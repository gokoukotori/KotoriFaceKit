# HandGesturePatternType(enum)

msgid "HandGesturePatternType:enum:LeftOnly"
msgstr "左手のみ"

msgid "HandGesturePatternType:enum:LeftOnly:Desc"
msgstr "左手のみのパターンです。(8通り)"

msgid "HandGesturePatternType:enum:RightOnly"
msgstr "右手のみ"

msgid "HandGesturePatternType:enum:RightOnly:Desc"
msgstr "右手のみのパターンです。(8通り)"

msgid "HandGesturePatternType:enum:BasicRight"
msgstr "右手優先"

msgid "HandGesturePatternType:enum:BasicRight:Desc"
msgstr "右手が優先される基本的なパターンです。(16通り)"

msgid "HandGesturePatternType:BasicLeft"
msgstr "左手優先"

msgid "HandGesturePatternType:enum:BasicLeft:Desc"
msgstr "左手が優先される基本的なパターンです。(16通り)"

msgid "HandGesturePatternType:enum:HandSign"
msgstr "両手全パターン"

msgid "HandGesturePatternType:enum:HandSign:Desc"
msgstr "左手と右手の組み合わせで最大64通りのジェスチャーを作成できるパターンです。(64通り)"

msgid "HandGesturePatternType:enum:Blending"
msgstr "両手のブレンド"

msgid "HandGesturePatternType:enum:Blending:Desc"
msgstr "片手ごとのアニメーションがブレンドさせるパターンです。目と口の制御をそれぞれの手に割り当てる際などに便利です。(64通り)"

